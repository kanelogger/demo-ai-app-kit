{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "workflow-state.schema.json",
  "title": "Workflow State",
  "description": "PDCA 流程状态——机器可读的阶段锁",
  "type": "object",
  "properties": {
    "stage": {
      "type": "string",
      "enum": [
        "requirements-draft",
        "user-confirmed",
        "solution-selected",
        "implementation-ready"
      ],
      "description": "当前阶段"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "selectedBy": {
      "type": ["string", "null"],
      "enum": ["user", "agent-default", null],
      "description": "方案选择来源：仅当用户显式说'你替我选'时使用 agent-default"
    },
    "lastUpdatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["stage", "startedAt"],
  "additionalProperties": false
}
