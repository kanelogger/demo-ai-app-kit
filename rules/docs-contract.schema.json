{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs-contract.schema.json",
  "title": "Docs Contract",
  "description": "阶段文档契约——定义阶段间的依赖关系",
  "type": "object",
  "properties": {
    "prerequisite": {
      "type": "string",
      "description": "前一阶段的文档路径（必须存在且有内容）"
    },
    "output": {
      "type": "string",
      "description": "当前阶段的产出文档路径"
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "阶段通过条件"
    }
  },
  "required": ["prerequisite", "output", "acceptanceCriteria"],
  "additionalProperties": false
}
