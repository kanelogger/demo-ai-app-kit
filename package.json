{
  "name": "kit-test",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-friendly PC 后台项目快速搭建工具",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "cli": "node packages/cli/dist/index.js",
    "clean": "pnpm -r exec rimraf dist node_modules && rimraf node_modules pnpm-lock.yaml",
    "check-stage": "node scripts/check-stage.mjs",
    "template:install": "cd templates/pc-admin && pnpm install",
    "template:dev": "cd templates/pc-admin && pnpm dev",
    "template:mysql": "docker compose up -d mysql"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.4.0"
}
