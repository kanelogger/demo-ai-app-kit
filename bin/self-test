#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const os = require('os');
const { execFileSync } = require('child_process');

const kitRoot = path.resolve(__dirname, '..');
const demoAiApp = path.join(kitRoot, 'bin', 'demo-ai-app');
const checkDemo = path.join(kitRoot, 'bin', 'check-demo');
const checkDocs = path.join(kitRoot, 'bin', 'check-docs');
const projectName = `kit-selftest-${Date.now()}`;
const workDir = os.tmpdir();
const projectDir = path.join(workDir, projectName);

function runCommand(command, args) {
  return execFileSync(command, args, { encoding: 'utf8', cwd: projectDir });
}

function expectCommand(label, command, args, shouldPass, expectedFailures) {
  let output;
  try {
    output = runCommand(command, args);
  } catch (err) {
    output = err.stdout || '';
    if (shouldPass) {
      console.error(output);
      console.error(`Self-test: FAIL - expected ${label} to PASS for ${projectDir}`);
      process.exit(1);
    }
    if (expectedFailures) {
      for (const expected of expectedFailures) {
        if (!output.includes(expected)) {
          console.error(output);
          console.error(`Self-test: FAIL - expected ${label} failure output to include: ${expected}`);
          process.exit(1);
        }
      }
    }
    return output;
  }
  if (!shouldPass) {
    console.error(output);
    console.error(`Self-test: FAIL - expected ${label} to FAIL for ${projectDir}`);
    process.exit(1);
  }
  return output;
}

function expectCheck(args, shouldPass, expectedFailures) {
  return expectCommand('check-demo', checkDemo, args, shouldPass, expectedFailures);
}

function expectDocs(args, shouldPass, expectedFailures) {
  return expectCommand('check-docs', checkDocs, args, shouldPass, expectedFailures);
}

function fillDocs(dir) {
  const docs = {
    'docs/requirements/requirements.md': `# Requirements

## Clarifications

