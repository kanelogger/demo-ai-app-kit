## Readiness Check

| Test ID | Scenario | Source | Steps | Expected Result |
|---------|----------|--------|-------|-----------------|
| RC-001 | check-demo | tech-plan.md | Run ./bin/check-demo . | PASS |
`
  };
  for (const [relPath, content] of Object.entries(docs)) {
    fs.writeFileSync(path.join(dir, relPath), content);
  }
}

let exitCode = 0;
try {
  execFileSync(process.execPath, [demoAiApp, projectName], { stdio: 'inherit', cwd: workDir });

  // Phase 1: skeleton project must pass skeleton mode.
  expectCheck(['--skeleton', '.'], true);

  // Phase 2: full mode must FAIL because docs are unfilled placeholders.
  expectCheck(['.'], false, [
    'FAIL: docs/requirements.md has no obvious placeholders',
    'FAIL: docs/tech-plan.md has no obvious placeholders',
    'FAIL: docs/workflow-integration.md has no obvious placeholders',
    'FAIL: docs/test-report.md has no obvious placeholders',
  ]);

  // Phase 3: fill docs and expect full PASS.
  fillDocs(projectDir);
  expectCheck(['.'], true);

  // Phase 4: forbidden source terms detector must FAIL on week-report wording.
  const templatesDir = path.join(projectDir, 'templates');
  fs.writeFileSync(path.join(templatesDir, 'residue_probe.html'), '<div>周报</div>\n');
  expectCheck(['--skeleton', '.'], false, [
    'FAIL: no forbidden source terms in generated app surfaces',
  ]);

  console.log('Self-test: PASS');
} catch (err) {
  console.error('Self-test: FAIL');
  exitCode = 1;
} finally {
  try {
    fs.rmSync(projectDir, { recursive: true, force: true });
  } catch (e) {
    // ignore cleanup failures
  }
}
process.exit(exitCode);
