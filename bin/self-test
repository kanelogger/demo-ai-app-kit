  };
  for (const [relPath, content] of Object.entries(docs)) {
    fs.writeFileSync(path.join(dir, relPath), content);
  }
}

let exitCode = 0;
try {
  execFileSync(process.execPath, [demoAiApp, projectName], { stdio: 'inherit', cwd: workDir });

  // Phase 1: skeleton project must pass skeleton mode.
  expectCheck(['--skeleton', '.'], true);

  // Phase 2: docs-only mode must FAIL because generated docs are unfilled placeholders.
  expectDocs(['.'], false, [
    'FAIL: docs/requirements/requirements.md has no obvious placeholders',
    'FAIL: docs/technical/tech-plan.md has no obvious placeholders',
    'FAIL: docs/technical/workflow-integration.md has no obvious placeholders',
    'Document quality: FAIL',
  ]);

  // Phase 3: full mode must FAIL because docs are unfilled placeholders.
  expectCheck(['.'], false, [
    'FAIL: docs/requirements/requirements.md has no obvious placeholders',
    'FAIL: solution selection fields are filled',
    'FAIL: docs/requirements/solution-options.md has no obvious placeholders',
    'FAIL: docs/technical/tech-plan.md has no obvious placeholders',
    'FAIL: docs/technical/workflow-integration.md has no obvious placeholders',
    'FAIL: docs/execution/test-report.md has no obvious placeholders',
    'FAIL: skill trace has no pending status',
    'FAIL: docs/execution/skill-trace.md has no obvious placeholders',
  ]);

  // Phase 4: fill docs and expect docs-only and full PASS.
  fillDocs(projectDir);
  expectDocs(['.'], true);
  expectCheck(['.'], true);

  // Phase 5: forbidden source terms detector must FAIL on week-report wording.
  const templatesDir = path.join(projectDir, 'templates');
  fs.writeFileSync(path.join(templatesDir, 'residue_probe.html'), '<div>周报</div>\n');
  expectCheck(['--skeleton', '.'], false, [
    'FAIL: no forbidden source terms in generated app surfaces',
  ]);

  console.log('Self-test: PASS');
} catch (err) {
  console.error('Self-test: FAIL');
  exitCode = 1;
} finally {
  try {
    fs.rmSync(projectDir, { recursive: true, force: true });
  } catch (e) {
    // ignore cleanup failures
  }
}
process.exit(exitCode);
