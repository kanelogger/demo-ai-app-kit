#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const os = require('os');
const { execFileSync } = require('child_process');

const kitRoot = path.resolve(__dirname, '..');
const demoAiApp = path.join(kitRoot, 'bin', 'demo-ai-app');
const checkDemo = path.join(kitRoot, 'bin', 'check-demo');
const projectName = `kit-selftest-${Date.now()}`;
const workDir = os.tmpdir();
const projectDir = path.join(workDir, projectName);

function runCheck(args) {
  return execFileSync(checkDemo, args, { encoding: 'utf8', cwd: projectDir });
}

function expectCheck(args, shouldPass, expectedFailures) {
  let output;
  try {
    output = runCheck(args);
  } catch (err) {
    output = err.stdout || '';
    if (shouldPass) {
      console.error(output);
      console.error(`Self-test: FAIL - expected check-demo to PASS for ${projectDir}`);
      process.exit(1);
    }
    if (expectedFailures) {
      for (const expected of expectedFailures) {
        if (!output.includes(expected)) {
          console.error(output);
          console.error(`Self-test: FAIL - expected failure output to include: ${expected}`);
          process.exit(1);
        }
      }
    }
    return output;
  }
  if (!shouldPass) {
    console.error(output);
    console.error(`Self-test: FAIL - expected check-demo to FAIL for ${projectDir}`);
    process.exit(1);
  }
  return output;
}

function fillDocs(dir) {
  const docs = {
    'docs/requirements.md': `# Requirements

## Clarifications

| Question | Answer | Answer Type | Decision Impact |
|----------|--------|-------------|-----------------|
| Who submits the request? | Community resident | Behavior Fact | Primary user |
| What is the core entity? | Repair request | Data Fact | Entity mapping |

## Assumptions

| Assumption | Reason | Risk if Wrong |
|------------|--------|---------------|
| Single demo account is enough | Local prototype | Add login flow later |

## Requirements Baseline

- Primary user: community resident
- Primary loop: resident submits a repair request and receives an AI-generated triage suggestion
- Core entity: repair request
- Core states: pending, assigned, closed
- Workflow input: request description
- Workflow output: triage category and suggested handler
- Acceptance check: a resident can submit a request and see a suggestion
- Out of scope: real notification channels, multi-tenant auth

## Primary Loop

1. Resident logs in.
2. Resident opens the repair create page.
3. Resident enters a description and submits.
4. App calls the AI workflow adapter.
5. App displays the triage suggestion.

## Acceptance Checks

- [ ] Primary loop works end-to-end locally.
- [ ] AI workflow adapter has a mock fallback with the same response shape.
- [ ] README documents run command, URL, and demo account if any.
- [ ] \`bin/check-demo .\` passes.

## Out of Scope

- Multi-tenant authentication.
- External notification channels.
`,
    'docs/tech-plan.md': `# Technical Plan

## Requirements Baseline Reference

- Primary user: community resident
- Primary loop: resident submits a repair request and receives an AI-generated triage suggestion
- Core entity: repair request
- Core states: pending, assigned, closed
- Workflow input: request description
- Workflow output: triage category and suggested handler
- Acceptance check: a resident can submit a request and see a suggestion
- Out of scope: real notification channels, multi-tenant auth

## Reference Patterns

| Pattern | Source File | Why Used |
|---------|-------------|----------|
| pc-admin-tech-plan-pattern | docs/template-patterns/pc-admin-tech-plan-pattern.md | Derive plan from baseline |
