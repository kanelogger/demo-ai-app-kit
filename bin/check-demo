#!/usr/bin/env bash
set -euo pipefail

ROOT="."
SKELETON_MODE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --skeleton)
      SKELETON_MODE=1
      shift
      ;;
    *)
      ROOT="$1"
      shift
      ;;
  esac
done

failures=0

is_kit_repo() {
  if [[ -f "$ROOT/package.json" ]] && grep -Eq '"name"\s*:\s*"demo-ai-app-kit"' "$ROOT/package.json"; then
    return 0
  fi
  return 1
}

check_file() {
  local path="$1"
  local label="$2"
  if [[ ! -f "$ROOT/$path" ]]; then
    echo "FAIL: missing $label: $path"
    failures=$((failures + 1))
  else
    echo "PASS: $label"
  fi
}

check_dir() {
  local path="$1"
  local label="$2"
  if [[ ! -d "$ROOT/$path" ]]; then
    echo "FAIL: missing $label: $path"
    failures=$((failures + 1))
  else
    echo "PASS: $label"
  fi
}

check_any_file() {
  local label="$1"
  shift
  local found=0
  for path in "$@"; do
    if [[ -f "$ROOT/$path" ]]; then
      found=1
      break
    fi
  done
  if [[ "$found" -eq 0 ]]; then
    echo "FAIL: missing $label: $*"
    failures=$((failures + 1))
  else
    echo "PASS: $label"
  fi
}

check_text() {
  local path="$1"
  local pattern="$2"
  local label="$3"
  if [[ ! -f "$ROOT/$path" ]]; then
    echo "FAIL: cannot check $label; missing $path"
    failures=$((failures + 1))
    return
  fi
  if grep -Eiq "$pattern" "$ROOT/$path"; then
    echo "PASS: $label"
  else
    echo "FAIL: $label"
    failures=$((failures + 1))
  fi
}

check_no_private_text() {
  local label="no private event material references"
  if grep -RInE "private-event|访问码|平台操作手册" "$ROOT" \
    --exclude-dir .git \
    --exclude-dir node_modules \
    --exclude-dir .venv \
    --exclude check-demo \
    --exclude TODO.md \
    --exclude private-event-requirements.md >/tmp/demo_check_private_hits.$$ 2>/dev/null; then
    echo "FAIL: $label"
    cat /tmp/demo_check_private_hits.$$
    rm -f /tmp/demo_check_private_hits.$$
    failures=$((failures + 1))
  else
    echo "PASS: $label"
    rm -f /tmp/demo_check_private_hits.$$
  fi
}

check_no_placeholders() {
  local doc="$1"
  local label="$doc has no obvious placeholders"
  if [[ ! -f "$ROOT/$doc" ]]; then
    return
  fi
  if grep -Eiq "Fill this in|^\s*- Primary user:\s*$|Do not build \.|^\s*\.\.\.\s*$|PASS / FAIL|# exact command|TODO|FIXME|\[Fill in" "$ROOT/$doc"; then
    echo "FAIL: $label"
    failures=$((failures + 1))
  else
    echo "PASS: $label"
  fi
}

check_not_placeholder_text() {
  local path="$1"
  local pattern="$2"
  local label="$3"
  if [[ ! -f "$ROOT/$path" ]]; then
    echo "FAIL: cannot check $label; missing $path"
    failures=$((failures + 1))
    return
  fi
  if grep -Eiq "$pattern" "$ROOT/$path"; then
    echo "FAIL: $label"
    failures=$((failures + 1))
  else
    echo "PASS: $label"
  fi
}

check_curl_available() {
  if command -v curl >/dev/null 2>&1; then
    return 0
  fi
  echo "FAIL: curl is required for DEMO_BASE_URL probes"
  failures=$((failures + 1))
  return 1
}

check_running_app_probe() {
  if [[ -z "${DEMO_BASE_URL:-}" ]]; then
    echo "SKIP: running app probe (set DEMO_BASE_URL, DEMO_PRIMARY_LOOP_PATH, DEMO_BUSINESS_API_PATH, DEMO_BUSINESS_API_PAYLOAD)"
    return
  fi

  check_curl_available || return

  local base="${DEMO_BASE_URL%/}"
  local page_path="${DEMO_PRIMARY_LOOP_PATH:-/}"
  local api_path="${DEMO_BUSINESS_API_PATH:-}"
  local payload="${DEMO_BUSINESS_API_PAYLOAD:-}"

  local page_code
  page_code="$(curl -s -o /tmp/demo_check_primary_page.$$ -w '%{http_code}' "$base$page_path" || true)"
  rm -f /tmp/demo_check_primary_page.$$
  if [[ "$page_code" =~ ^(200|302)$ ]]; then
    echo "PASS: primary loop page responds ($page_code)"
  else
    echo "FAIL: primary loop page responds ($page_code) at $base$page_path"
    failures=$((failures + 1))
  fi

  if [[ -z "$api_path" || -z "$payload" ]]; then
    echo "FAIL: business API probe requires DEMO_BUSINESS_API_PATH and DEMO_BUSINESS_API_PAYLOAD"
    failures=$((failures + 1))
    return
  fi

  local response_file="/tmp/demo_check_business_api.$$"
  local api_code
  api_code="$(curl -s -o "$response_file" -w '%{http_code}' \
    -X POST "$base$api_path" \
    -H 'Content-Type: application/json' \
    -d "$payload" || true)"

  if [[ "$api_code" =~ ^(200|400)$ ]]; then
    echo "PASS: business API responds ($api_code)"
  else
    echo "FAIL: business API responds ($api_code) at $base$api_path"
    cat "$response_file" 2>/dev/null || true
    rm -f "$response_file"
    failures=$((failures + 1))
    return
  fi

  if python3 - "$response_file" <<'PY'
import json
import sys

path = sys.argv[1]
with open(path, "r", encoding="utf-8") as fh:
    data = json.load(fh)

required = {"ok", "data", "error", "fallback"}
missing = sorted(required.difference(data))
if missing:
    print("missing keys: " + ", ".join(missing))
    sys.exit(1)

if not isinstance(data.get("ok"), bool):
    print("ok must be boolean")
    sys.exit(1)

if not isinstance(data.get("fallback"), bool):
    print("fallback must be boolean")
    sys.exit(1)
PY
  then
    echo "PASS: business API returns stable JSON envelope"
  else
    echo "FAIL: business API returns stable JSON envelope"
    cat "$response_file" 2>/dev/null || true
    failures=$((failures + 1))
  fi
  rm -f "$response_file"
}

check_forbidden_source_terms() {
  local label="no forbidden source terms in generated app surfaces"
  local zh_report="周""报"
  local zh_pending="待我""填报"
  local zh_mine="我填报的""周""报"
  local zh_review="待我""审核"
  local zh_view="周""报""查看"
  local zh_template="周""报""模板"
  local en_wr="week""-""report"
  local en_weekly="weekly ""report"
  local en_template="report ""template"
  local old_shell="flask-adminlte""-week""-report"
  local old_skill="template""-adapter"
  local pattern="${zh_report}|${en_wr}|${en_weekly}|${en_template}|${zh_pending}|${zh_mine}|${zh_review}|${zh_view}|${zh_template}|${old_shell}|${old_skill}"
  local hits_file="/tmp/demo_check_forbidden_hits.$$"

  if is_kit_repo; then
    echo "SKIP: $label (kit repo may keep source wording)"
    return
  fi

  # Search app surfaces only. Kit instructions (AGENTS.md, prompts/, skills/,
  # bin/check-demo) are allowed to mention forbidden labels in rules.
  local search_paths=()
  for scope in \
    "app.py" "workflow_adapter.py" "README.md" \
    "templates" "assets" \
    "docs/requirements/requirements.md" "docs/requirements/solution-options.md" \
    "docs/technical/tech-plan.md" "docs/technical/workflow-integration.md" \
    "docs/technical/test-cases.md" "docs/execution/test-report.md"; do
    if [[ -e "$ROOT/$scope" ]]; then
      search_paths+=("$ROOT/$scope")
    fi
  done

  if [[ ${#search_paths[@]} -eq 0 ]]; then
    echo "PASS: $label (no generated-facing scopes to check)"
    return
  fi

  if grep -RInE "$pattern" "${search_paths[@]}" 2>/dev/null >"$hits_file"; then
    echo "FAIL: $label"
    cat "$hits_file"
    rm -f "$hits_file"
    failures=$((failures + 1))
  else
    echo "PASS: $label"
    rm -f "$hits_file"
  fi
}

check_no_copied_reference_paths() {
  local label="no copied reference/example paths in generated app surfaces"
  local pattern='examples/|docs/reference/'
  local hits_file="/tmp/demo_check_paths_hits.$$"

  if is_kit_repo; then
    echo "SKIP: $label (kit repo contains reference paths)"
    return
  fi

  # Search app surfaces only. Kit instructions are allowed to reference paths in rules.
  local search_paths=()
  for scope in \
    "app.py" "workflow_adapter.py" "README.md" \
    "templates" "assets" \
    "docs/requirements/requirements.md" "docs/requirements/solution-options.md" \
    "docs/technical/tech-plan.md" "docs/technical/workflow-integration.md" \
    "docs/technical/test-cases.md" "docs/execution/test-report.md"; do
    if [[ -e "$ROOT/$scope" ]]; then
      search_paths+=("$ROOT/$scope")
    fi
  done

  if [[ ${#search_paths[@]} -eq 0 ]]; then
    echo "PASS: $label (no generated-facing scopes to check)"
    return
  fi

  if grep -RInE "$pattern" "${search_paths[@]}" 2>/dev/null >"$hits_file"; then
    echo "FAIL: $label"
    cat "$hits_file"
    rm -f "$hits_file"
    failures=$((failures + 1))
  else
    echo "PASS: $label"
    rm -f "$hits_file"
  fi
}

if is_kit_repo; then
  echo "Mode: kit repo readiness"
elif [[ "$SKELETON_MODE" -eq 1 ]]; then
  echo "Mode: skeleton readiness"
else
  echo "Mode: generated app readiness"
fi

check_file "README.md" "README"
if is_kit_repo; then
  check_any_file "app entry" "templates/flask-admin-shell/app.py"
else
  check_any_file "app entry" "app.py" "src/app.py" "server.py"
fi

# Skeleton checks: always run for generated projects, regardless of mode.
if ! is_kit_repo; then
  check_file "app.py" "app entry"
  check_file "workflow_adapter.py" "workflow adapter"
  check_file "bin/check-demo" "check-demo script"
  check_file "kit/checkers/check-docs" "check-docs script"
  check_dir "kit" "kit initialization folder"
  check_dir "kit/template-patterns" "pattern registry"
  check_file "kit/prompts/opencode-entry.md" "entry prompt"
  check_dir "kit/skills/shell-implementation" "shell-implementation skill"
  check_file "docs/requirements/solution-options.md" "solution options document"
  check_file "docs/technical/test-cases.md" "test cases document"
  check_file "docs/execution/skill-trace.md" "skill trace document"
  check_file "templates/base.html" "base template"
  check_file "templates/layout.html" "layout template"
  check_file "templates/auth/login.html" "login template"
  check_file "templates/dashboard/index.html" "dashboard template"
  check_file "assets/styles.css" "styles"
  check_file "assets/app.js" "app script"
  check_forbidden_source_terms
  check_no_copied_reference_paths
fi

# Full-mode checks for completed apps.
if ! is_kit_repo && [[ "$SKELETON_MODE" -eq 0 ]]; then
  check_file "docs/requirements/requirements.md" "requirements document"
  check_file "docs/requirements/solution-options.md" "solution options document"
  check_file "docs/technical/tech-plan.md" "technical plan"
  check_file "docs/technical/workflow-integration.md" "workflow integration document"
  check_file "docs/execution/skill-trace.md" "skill trace document"
  check_file "docs/execution/test-report.md" "test report"

  check_text "README.md" "PC|后台|admin|workbench|管理" "README identifies PC backend/admin app"
  check_text "README.md" "run|启动|运行|python|npm|flask" "README includes run instructions"
  check_text "README.md" "127\.0\.0\.1|localhost|http://" "README includes local URL"
  check_text "README.md" "primary loop|主闭环|primary user loop|核心流程" "README includes primary loop"
  check_text "README.md" "mock|fallback|兜底|模拟" "README includes mock fallback"
  check_text "README.md" "workflow|工作流|agent|智能体" "README includes workflow integration notes"
  check_text "README.md" "docs/requirements/requirements\.md|docs/requirements/solution-options\.md|docs/technical/tech-plan\.md|Project artifacts|产物" "README explains standard docs artifacts"

  check_text "docs/requirements/solution-options.md" "Option 1|方案一|方案 1" "solution options include option 1"
  check_text "docs/requirements/solution-options.md" "Option 2|方案二|方案 2" "solution options include option 2"
  check_text "docs/requirements/solution-options.md" "Option 3|方案三|方案 3" "solution options include option 3"
  check_text "docs/requirements/solution-options.md" "Recommendation|推荐" "solution options include recommendation"
  check_text "docs/requirements/solution-options.md" "Selected option|选定方案|已选方案" "solution options record selected option"
  check_not_placeholder_text "docs/requirements/solution-options.md" "Selected option:\\s*$|Selected by:\\s*$|Selected at:\\s*$" "solution selection fields are filled"

  check_text "docs/technical/tech-plan.md" "Selected Solution Reference|选定方案|已选方案" "tech plan references selected solution"
  check_text "docs/technical/tech-plan.md" "Primary Loop API|Business API endpoint|业务 API|业务接口" "tech plan includes primary loop API"
  check_text "docs/technical/tech-plan.md" "Menu Plan|菜单规划" "tech plan includes Menu Plan"
  check_text "docs/technical/tech-plan.md" "Page Plan|页面规划|页面分层" "tech plan includes Page Plan"
  check_text "docs/technical/tech-plan.md" "Field Mapping|字段映射" "tech plan includes Field Mapping"
  check_text "docs/technical/tech-plan.md" "Workflow Mock Contract|Workflow Mock|Mock Contract" "tech plan includes Workflow Mock Contract"

  check_text "README.md" "workflow_adapter|Core modules|核心模块|模块说明" "README includes workflow adapter / module description"
  check_text "docs/technical/workflow-integration.md" "timeout|TIMEOUT|超时" "workflow doc covers timeout strategy"
  check_text "docs/technical/workflow-integration.md" "empty|EMPTY|空结果" "workflow doc covers empty result strategy"
  check_text "docs/technical/workflow-integration.md" "invalid|INVALID_INPUT|非法输入" "workflow doc covers invalid input strategy"
  check_text "docs/technical/workflow-integration.md" "failure|platform error|FAILURE|失败" "workflow doc covers failure strategy"

  check_text "docs/execution/skill-trace.md" "\\bused\\b|已使用|使用" "skill trace records used skills"
  check_text "docs/execution/skill-trace.md" "\\bskipped\\b|已跳过|跳过" "skill trace records skipped skills"
  check_not_placeholder_text "docs/execution/skill-trace.md" "\\bpending\\b" "skill trace has no pending status"

  # Basic non-empty checks for standard docs.
  for doc in docs/requirements/requirements.md docs/requirements/solution-options.md docs/technical/tech-plan.md docs/technical/workflow-integration.md docs/execution/test-report.md docs/technical/test-cases.md docs/execution/skill-trace.md; do
    if [[ -f "$ROOT/$doc" ]] && [[ ! -s "$ROOT/$doc" ]]; then
      echo "FAIL: $doc is empty"
      failures=$((failures + 1))
    elif [[ -f "$ROOT/$doc" ]]; then
      echo "PASS: $doc is not empty"
    fi
  done

  # Content-quality guard: detect obvious unfilled placeholders.
  for doc in docs/requirements/requirements.md docs/requirements/solution-options.md docs/technical/tech-plan.md docs/technical/workflow-integration.md docs/execution/test-report.md docs/execution/skill-trace.md; do
    check_no_placeholders "$doc"
  done

  check_running_app_probe
fi

check_no_private_text

if [[ "$failures" -gt 0 ]]; then
  echo "Demo readiness: FAIL ($failures issue(s))"
  exit 1
fi

echo "Demo readiness: PASS"
