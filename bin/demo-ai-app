#!/usr/bin/env node
const fs = require('fs');
const path = require('path');

const projectName = process.argv[2];

if (!projectName) {
  console.error('Usage: demo-ai-app <project-name>');
  process.exit(1);
}

if (!/^[a-zA-Z0-9_-]+$/.test(projectName)) {
  console.error('Error: project name must be alphanumeric with - or _ only.');
  process.exit(1);
}

const kitRoot = path.resolve(__dirname, '..');
const targetDir = path.resolve(process.cwd(), projectName);

if (fs.existsSync(targetDir)) {
  console.error(`Error: directory already exists: ${targetDir}`);
  process.exit(1);
}

const coreSkills = [
  'question-refiner',
  'ce-brainstorm',
  'grilling',
  'solution-stress-test',
  'domain-modeling',
  'tech-plan-generator',
  'api-and-interface-design',
  'security-and-hardening',
  'template-adapter',
  'workflow-integration-planner',
  'tdd',
  'webapp-testing',
  'debugging-and-error-recovery',
  'code-review-and-quality',
  'implement',
  'planning-and-task-breakdown',
];

// Validate required source assets before creating the target directory so a
// missing skill or template does not leave a half-generated project behind.
const requiredSources = [
  ['template', path.join(kitRoot, 'templates', 'flask-adminlte-week-report')],
  ['docs skeletons', path.join(kitRoot, 'templates', 'docs')],
  ['AGENTS.md', path.join(kitRoot, 'AGENTS.md')],
  ['entry prompt', path.join(kitRoot, 'prompts', 'opencode-entry.md')],
  ['check-demo script', path.join(kitRoot, 'bin', 'check-demo')],
  ...coreSkills.map((skill) => [`skill/${skill}`, path.join(kitRoot, 'skills', skill)]),
];

for (const [label, src] of requiredSources) {
  if (!fs.existsSync(src)) {
    console.error(`Error: required kit asset is missing: ${label} (${src})`);
    process.exit(1);
  }
}

fs.mkdirSync(targetDir, { recursive: true });

const SKIP_DIRS = new Set(['node_modules', '.git', '__pycache__', '.venv', 'venv', 'env']);

function copyDir(src, dest) {
  fs.mkdirSync(dest, { recursive: true });
  for (const entry of fs.readdirSync(src, { withFileTypes: true })) {
    const srcPath = path.join(src, entry.name);
    const destPath = path.join(dest, entry.name);
    if (entry.isDirectory()) {
      if (SKIP_DIRS.has(entry.name)) continue;
      copyDir(srcPath, destPath);
    } else {
      fs.copyFileSync(srcPath, destPath);
    }
  }
}

function copyFile(src, dest) {
  fs.mkdirSync(path.dirname(dest), { recursive: true });
  fs.copyFileSync(src, dest);
}


// 1. Copy bundled template as the generated app skeleton.
copyDir(path.join(kitRoot, 'templates', 'flask-adminlte-week-report'), targetDir);

// 2. Copy standard project documentation skeletons.
copyDir(path.join(kitRoot, 'templates', 'docs'), path.join(targetDir, 'docs'));

// 3. Copy project-level agent instructions.
copyFile(path.join(kitRoot, 'AGENTS.md'), path.join(targetDir, 'AGENTS.md'));

// 4. Copy entry prompt.
copyFile(path.join(kitRoot, 'prompts', 'opencode-entry.md'), path.join(targetDir, 'prompts', 'opencode-entry.md'));

// 5. Copy core skills; fail loud if a default-path skill is missing from the kit.
for (const skill of coreSkills) {
  const src = path.join(kitRoot, 'skills', skill);
  if (!fs.existsSync(src)) {
    console.error(`Error: required skill is missing from the kit: ${skill}`);
    process.exit(1);
  }
  copyDir(src, path.join(targetDir, 'skills', skill));
}

// 6. Copy check-demo script.
copyFile(path.join(kitRoot, 'bin', 'check-demo'), path.join(targetDir, 'bin', 'check-demo'));
fs.chmodSync(path.join(targetDir, 'bin', 'check-demo'), 0o755);

// 7. Generate a project README skeleton.
const readme = `# ${projectName}

Generated from demo-ai-app-kit.

## Purpose

A locally runnable AI web app prototype built by adapting the bundled Flask + AdminLTE admin shell.

**业务类型 / Business type**: [Fill in target business, e.g. 社区报修 / community repair]

This generated directory is an Agent workspace, not a finished app. The Flask
template can run immediately, but \`bin/check-demo\` is expected to fail until
the Agent replaces the placeholder docs, adapts the template to the target
domain, verifies the app, and updates this README.

## Target workflow

\`\`\`text
Input a simple app requirement
-> Agent reads prompts/opencode-entry.md and AGENTS.md
-> Requirement clarification (question-refiner / ce-brainstorm)
-> Solution stress test and domain modeling
-> SDD-lite technical plan
-> Adapt templates/ into the target app
-> Integrate or mock the AI workflow
-> Local verification and check-demo
-> Quality review
\`\`\`

## Run locally

\`\`\`bash
python3 -m venv .venv
source .venv/bin/activate        # Windows: .venv\\Scripts\\activate
pip install -r requirements.txt
python3 app.py
\`\`\`

Open http://127.0.0.1:5000 in a browser.

Default demo account: \`ADMIN001 / admin123\`.

The project was generated with \`demo-ai-app ${projectName}\`; if you are reading this inside the project directory, run \`python3 app.py\` directly after installing \`requirements.txt\`.

## Project structure

\`\`\`text
.
├── app.py                    # Flask entry point and routes
├── workflow_adapter.py       # AI workflow adapter: validate, timeout, mock fallback, error envelope
├── requirements.txt          # Python dependencies
├── bin/check-demo            # Demo readiness check
├── docs/                     # Product-quality workflow artifacts
│   ├── requirements.md
│   ├── tech-plan.md
│   ├── workflow-integration.md
│   └── test-report.md
├── templates/                # Jinja2 / HTML templates
└── assets/                   # CSS, JS, images
\`\`\`

## Core modules

| File | Purpose |
|------|---------|
| \`app.py\` | Flask application entry point, page routes, and API endpoints. |
| \`workflow_adapter.py\` | Replaceable adapter for the AI workflow: input validation, timeout, empty-result fallback, and a stable \`{ok, data, error, fallback}\` response envelope. |
| \`bin/check-demo\` | Readiness script that checks required files, README contents, and workflow error-handling contract. |

## Template Adaptation Contract

The bundled template is a generic PC admin shell derived from a week-report system. Before adapting it to a target business, the Agent must produce a written contract in \`docs/tech-plan.md\`:

- \`Menu Plan\`: system name, top-level menus, sub-menus, target routes, and layer.
- \`Page Plan\`: every page with route, purpose, source template, layer, keep reason, and cut plan.
- \`Entity Mapping\`: each source template entity mapped to a target business entity.
- \`Field Mapping\`: UI field -> local/API field -> workflow field -> mock fixture field.
- \`Copy Rewrite Checklist\`: every visible text item that must be rewritten to the target domain.

### Page layers

| Layer | Meaning | Policy |
|-------|---------|--------|
| \`core\` | Required to complete the primary loop | Must implement and verify |
| \`supporting\` | Relevant to the loop; improves demo credibility | Keep only with a written reason |
| \`foundation\` | Login, dashboard, users, roles, dictionaries, menus | Keep as needed; do not overshadow the loop |
| \`optional-cut\` | Business-relevant but not needed for the current demo | May keep; must record cut scope |
| \`delete\` | Unrelated to the target business or week-report leftover | Delete or hide from menus and docs |

Page count is not a target metric. Keep business-relevant pages and delete or weaken week-report-specific pages. Complete the primary loop before trimming \`optional-cut\` pages.

### Cut plan scope

For every \`optional-cut\` or \`delete\` page, record the scope needed to remove it later:

- Flask route in \`app.py\`.
- Jinja template or static HTML file.
- Sidebar / menu entry.
- Mock data in \`assets/mock-data.js\` or backend fixtures.
- JS event or render entry.
- References in README, docs, and test-report.

## AI workflow integration

The app calls the AI workflow through \`workflow_adapter.py\`. When the platform is unavailable or \`WORKFLOW_MOCK=true\`, the adapter falls back to a mock response with the same JSON shape.

Example request:

\`\`\`bash
curl -X POST http://127.0.0.1:5000/api/workflow/demo \\
  -H "Content-Type: application/json" \\
  -d '{"input": "hello workflow"}'
\`\`\`

Response envelope:

\`\`\`json
{
  "ok": true,
  "data": {"output": "mock processed: hello workflow", "confidence": 0.95, "processed_at": "..."},
  "error": null,
  "fallback": true
}
\`\`\`

Error responses use the same shape with \`ok: false\` and a non-null \`error\` object.

## Project artifacts

The Agent fills these standard files during the product-quality workflow:

| File | Purpose |
|------|---------|
| \`docs/requirements.md\` | Scoped requirements, users, primary loop, inputs/outputs, acceptance criteria. |
| \`docs/tech-plan.md\` | Stack, pages, data model, API contract, SDD-lite, test plan, known limits. |
| \`docs/workflow-integration.md\` | AI workflow adapter contract, request/response JSON, mock fallback, error handling. |
| \`docs/test-report.md\` | Local run, unit/browser tests, mock fallback tests, issue log, sign-off. |

Keep these files in sync with code and README.

Demo scripts, judge Q&A, and presentation notes are optional live-demo material.
They are not standard artifacts and are not required by \`bin/check-demo\`.

## Current status

- [ ] Requirement clarified
- [ ] SDD-lite contract written
- [ ] Template adapted
- [ ] Workflow adapter + mock fallback implemented
- [ ] Local verification passed
- [ ] README updated with exact run command and URL

## Known limits

- This is a prototype, not production code.
- Review all TODO comments before demo day.
`;
fs.writeFileSync(path.join(targetDir, 'README.md'), readme);

console.log(`Generated project at ${targetDir}`);
console.log(`Next steps:`);
console.log(`  cd ${projectName}`);
console.log(`  python3 app.py`);
console.log(`  # after Agent fills docs and adapts the app:`);
console.log(`  ./bin/check-demo .`);
