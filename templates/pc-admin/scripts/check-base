#!/usr/bin/env node
// check-base — 基础环境校验（Node 版本、pnpm 版本等）
// Usage: node scripts/check-base.mjs

import { access } from "node:fs/promises";
import { join } from "node:path";

async function check() {
  const checks = [];

  // Node version
  const nodeVersion = process.versions.node;
  const [major] = nodeVersion.split(".").map(Number);
  if (major < 20) {
    checks.push(`❌ Node.js >= 20 required, got ${nodeVersion}`);
  } else {
    checks.push(`✅ Node.js ${nodeVersion}`);
  }

  // pnpm lockfile exists
  try {
    await access(join(process.cwd(), "pnpm-lock.yaml"));
    checks.push("✅ pnpm-lock.yaml found");
  } catch {
    checks.push("⚠️  pnpm-lock.yaml not found (run pnpm install)");
  }

  for (const c of checks) console.log(c);
}

await check();
