{
  "compilerOptions": {
    "target": "ESNEXT",
    "module": "commonjs",
    "pretty": true,
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*.ts", ],
  "exclude": [
    "node_modules",
    "src/router/api/*.ts",
    "dist"
  ]
}
